<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="TagIp" suffix=" · PiEvents" phx-no-format>{assigns[:page_title]}</.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>

  <body class="bg-slate-50 min-h-screen flex flex-col font-sans antialiased text-slate-900">
    
<!-- HEADER : Immobile (Glassmorphism) -->
    <header
      :if={@current_user}
      class="flex-none sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-200/60 shadow-sm"
    >
      <div class="max-w-full mx-auto px-4 sm:px-6 lg:px-10">
        <div class="flex items-center justify-between h-16">
          
<!-- Logo & Brand -->
          <div class="flex items-center group">
            <a
              href="/"
              class="flex items-center gap-3 transition-transform duration-200 hover:scale-[1.02]"
            >
              <div class="flex items-center justify-center h-15 w-auto bg-white rounded-xl p-1 overflow-hidden">
                <img
                  class="h-full w-auto object-contain"
                  src={~p"/images/logo.png"}
                  alt="Logo Tag-IP"
                />
              </div>
              <span class="text-lg font-bold text-slate-900 tracking-tight">PI-Events</span>
            </a>
          </div>
          
<!-- Status de connexion -->
          <div class="flex items-center gap-3">
            <span class="hidden sm:inline-flex items-center gap-2 text-[11px] font-bold text-blue-600 bg-blue-50 px-3 py-1.5 rounded-full border border-blue-100 tracking-wide uppercase">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75">
                </span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-600"></span>
              </span>
              Connecté
            </span>
          </div>
        </div>
      </div>
    </header>
    
<!-- ZONE CENTRALE : La seule zone qui scrolle -->
    <main class={
      [
        "flex-1 w-full px-4 sm:px-6 lg:px-10 py-8 grid grid-cols-1 gap-8",
        # N'applique la grille 2 colonnes que si connecté
        @current_user && "lg:grid-cols-[280px_1fr]"
      ]
    }>
      
<!-- Sidebar de Navigation Moderne -->
      <aside :if={@current_user} class="sticky top-16 h-fit max-lg:static">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200/60 transition-shadow hover:shadow-md overflow-hidden">
          
<!-- Profil / Branding -->
          <div class="px-5 pt-5 pb-4 border-b border-slate-100">
            <div class="flex items-center gap-3">
              <div class="size-9 rounded-xl bg-gradient-to-br from-blue-600 to-blue-700 flex items-center justify-center shadow-sm shrink-0">
                <.icon name="hero-squares-2x2" class="size-4 text-white" />
              </div>
              <div>
                <p class="text-sm font-extrabold text-slate-900 tracking-tight">PI-Events</p>
                <p class="text-[10px] font-medium text-slate-400 tracking-wide">
                  Tableau de bord
                </p>
              </div>
            </div>
          </div>
          
<!-- Navigation -->
          <div class="p-4 space-y-5">
            
<!-- Section : Événements -->
            <div>
              <p class="px-3 mb-2 text-[10px] font-black text-slate-400 uppercase tracking-[0.15em]">
                Événements
              </p>
              <ul class="space-y-0.5">
                <li>
                  <.link
                    navigate="/"
                    class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold text-slate-600 hover:bg-blue-50 hover:text-blue-700 transition-all duration-150 group"
                  >
                    <span class="flex size-7 rounded-lg bg-slate-100 group-hover:bg-blue-100 items-center justify-center transition-colors duration-150">
                      <.icon
                        name="hero-home"
                        class="size-3.5 text-slate-500 group-hover:text-blue-600 transition-colors duration-150"
                      />
                    </span>
                    Accueil
                  </.link>
                </li>
                <li>
                  <.link
                    navigate="/dashboard"
                    class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold text-slate-600 hover:bg-blue-50 hover:text-blue-700 transition-all duration-150 group"
                  >
                    <span class="flex size-7 rounded-lg bg-slate-100 group-hover:bg-blue-100 items-center justify-center transition-colors duration-150">
                      <.icon
                        name="hero-chart-bar"
                        class="size-3.5 text-slate-500 group-hover:text-blue-600 transition-colors duration-150"
                      />
                    </span>
                    Dashboard
                  </.link>
                </li>
                <li>
                  <.link
                    navigate="/global-events"
                    class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold text-slate-600 hover:bg-blue-50 hover:text-blue-700 transition-all duration-150 group"
                  >
                    <span class="flex size-7 rounded-lg bg-slate-100 group-hover:bg-blue-100 items-center justify-center transition-colors duration-150">
                      <.icon
                        name="hero-globe-alt"
                        class="size-3.5 text-slate-500 group-hover:text-blue-600 transition-colors duration-150"
                      />
                    </span>
                    Catalogue global
                  </.link>
                </li>
                <li>
                  <.link
                    navigate="/global-events/new"
                    class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold text-slate-600 hover:bg-blue-50 hover:text-blue-700 transition-all duration-150 group"
                  >
                    <span class="flex size-7 rounded-lg bg-slate-100 group-hover:bg-blue-100 items-center justify-center transition-colors duration-150">
                      <.icon
                        name="hero-plus-circle"
                        class="size-3.5 text-slate-500 group-hover:text-blue-600 transition-colors duration-150"
                      />
                    </span>
                    Nouvel événement
                  </.link>
                </li>
                <li>
                  <.link
                    navigate="/org-events"
                    class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold text-slate-600 hover:bg-blue-50 hover:text-blue-700 transition-all duration-150 group"
                  >
                    <span class="flex size-7 rounded-lg bg-slate-100 group-hover:bg-blue-100 items-center justify-center transition-colors duration-150">
                      <.icon
                        name="hero-building-office"
                        class="size-3.5 text-slate-500 group-hover:text-blue-600 transition-colors duration-150"
                      />
                    </span>
                    Config. organisations
                  </.link>
                </li>
              </ul>
            </div>
            
<!-- Section : Système -->
            <div>
              <p class="px-3 mb-2 text-[10px] font-black text-slate-400 uppercase tracking-[0.15em]">
                Système
              </p>
              <ul class="space-y-0.5">
                <li>
                  <.link
                    navigate="/monitoring"
                    class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold text-slate-600 hover:bg-blue-50 hover:text-blue-700 transition-all duration-150 group"
                  >
                    <span class="flex size-7 rounded-lg bg-slate-100 group-hover:bg-blue-100 items-center justify-center transition-colors duration-150">
                      <.icon
                        name="hero-bell-alert"
                        class="size-3.5 text-slate-500 group-hover:text-blue-600 transition-colors duration-150"
                      />
                    </span>
                    Système d'alertes
                  </.link>
                </li>
                <li>
                  <.link
                    navigate="/init"
                    class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold text-slate-600 hover:bg-blue-50 hover:text-blue-700 transition-all duration-150 group"
                  >
                    <span class="flex size-7 rounded-lg bg-slate-100 group-hover:bg-blue-100 items-center justify-center transition-colors duration-150">
                      <.icon
                        name="hero-rocket-launch"
                        class="size-3.5 text-slate-500 group-hover:text-blue-600 transition-colors duration-150"
                      />
                    </span>
                    Initialisation
                  </.link>
                </li>
              </ul>
            </div>
          </div>
          
<!-- Widget d'info -->
          <div class="mx-4 mb-4 p-3.5 bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl border border-blue-100/60">
            <div class="flex items-start gap-2.5">
              <.icon name="hero-light-bulb" class="size-4 text-blue-500 mt-0.5 shrink-0" />
              <p class="text-[11px] text-blue-700/80 font-medium leading-relaxed">
                Configurez vos alertes depuis la section monitoring.
              </p>
            </div>
          </div>
        </div>
      </aside>
      
<!-- Contenu Dynamique -->
      <div class="space-y-6">
        <.flash_group flash={@flash} />
        {@inner_content}
      </div>
    </main>
    
<!-- FOOTER : Immobile et Moderne -->
    <footer
      :if={@current_user}
      class="flex-none bg-white/80 backdrop-blur-md border-t border-slate-200 py-4 shadow-[0_-4px_12px_rgba(0,0,0,0.03)]"
    >
      <div class="max-w-full mx-auto px-4 sm:px-6 lg:px-10 flex flex-col md:flex-row justify-between items-center gap-6">
        
<!-- Copyright & Version -->
        <div class="flex items-center gap-4 text-sm font-medium text-slate-500">
          <span>© 2026 <span class="text-slate-900 font-bold tracking-tight">Tag-IP</span></span>
          <span class="text-slate-200 text-lg">|</span>
          <span class="text-xs font-mono bg-slate-100 px-2 py-0.5 rounded text-slate-400">
            v1.2.0-stable
          </span>
        </div>
        
<!-- Status Pill Central -->
        <div class="flex items-center gap-3 px-4 py-1.5 bg-slate-50 border border-slate-200 rounded-full shadow-inner">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75">
            </span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          <span class="text-[10px] font-black text-slate-500 uppercase tracking-tighter">
            Flux de données actif
          </span>
        </div>
        
<!-- Liens secondaires -->
        <div class="flex gap-8 text-xs font-bold text-slate-400 uppercase tracking-widest">
          <a href="#" class="hover:text-blue-600 transition-colors">Support</a>
          <a href="#" class="hover:text-blue-600 transition-colors">Docs API</a>
        </div>
      </div>
    </footer>
  </body>
</html>
